Options -Indexes
ServerSignature Off

# Rewrite rules
RewriteEngine On
# RewriteBase намеренно не задан жёстко, чтобы сайт корректно работал и в корне домена, и в подпапке.

# Protect data directory
RewriteRule ^data/ - [F,L]

# Admin panel
RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^admin/(.+)$ admin/$1 [L]

# API routes
RewriteRule ^api/(.+)$ api/index.php?path=$1 [QSA,L]

# Sitemap and robots
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^robots\.txt$ robots.php [L]

# Public pages
RewriteRule ^catalog/?$ index.php?page=catalog [QSA,L]
RewriteRule ^category/([^/]+)/?$ index.php?page=category&slug=$1 [QSA,L]
RewriteRule ^category/([^/]+)/([^/]+)/?$ index.php?page=category&slug=$1&sub=$2 [QSA,L]
RewriteRule ^item/([^/]+)/?$ index.php?page=item&slug=$1 [QSA,L]
RewriteRule ^oplata/?$ index.php?page=oplata [QSA,L]
RewriteRule ^faq/?$ index.php?page=faq [QSA,L]
RewriteRule ^rules/?$ index.php?page=rules [QSA,L]
# Info/articles with pagination: /info/?page=2 -> pass page_num to info
RewriteCond %{QUERY_STRING} ^(.*&)?page=([0-9]+)(&.*)?$
RewriteRule ^info/?$ index.php?page=info&page_num=%2 [QSA,L]
RewriteRule ^info/?$ index.php?page=info [QSA,L]
RewriteRule ^info/([^/]+)/?$ index.php?page=info&article=$1 [QSA,L]
RewriteRule ^advertising/?$ index.php?page=advertising [QSA,L]

# Main index - fallback for all non-file/dir requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Gzip compression (enhanced)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml image/svg+xml
    AddOutputFilterByType DEFLATE font/woff font/woff2
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|zip|gz|bz2|rar)$ no-gzip dont-vary
</IfModule>

# Cache control (enhanced)
<IfModule mod_expires.c>
    ExpiresActive On
    # Images - long cache
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    # Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    # CSS & JS - medium cache
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    # HTML & JSON - no cache
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# Cache-Control headers for static assets
<IfModule mod_headers.c>
    <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    # Keep-Alive
    Header set Connection keep-alive
</IfModule>

# ETag
FileETag None
